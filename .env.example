ADMIN_ID=admin
ADMIN_PASSWORD=changeme
SESSION_SECRET=change-this-to-a-random-string-of-at-least-32-characters
# Base directory for the SQLite DB, uploaded files, and icons. Defaults to ./data
DATA_DIR=
# Override individual sub-paths. Each falls back to a DATA_DIR-relative default.
# Directory for uploaded files. Defaults to $DATA_DIR/files
FILES_DIR=
# Directory for project icons. Defaults to $DATA_DIR/icons
ICONS_DIR=
# Path to the SQLite DB file. Defaults to $DATA_DIR/deploy.db
DB_PATH=
